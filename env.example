# Premium analytics (server-side only — never expose keys to the client)
VOYYAGE_ANALYTICS_DEV=1
PREMIUM_ACCESS_SECRET=replace-with-long-random-secret-min-16-chars
ANALYTICS_SESSION_PASSWORD=replace-with-at-least-32-characters-for-portfolio-session

# Neon — https://console.neon.tech → your project → Connect
# DATABASE_URL = "Pooled connection" (app + Vercel)
# DATABASE_URL_UNPOOLED = "Direct connection" (migrations only; optional)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Admin — model portfolios at /admin
ADMIN_PASSWORD=replace-with-strong-admin-password-min-8-chars
VOYYAGE_ADMIN_DEV=1

# Market data (priority default: polygon,finnhub,twelvedata,alphavantage)
MARKET_DATA_PRIORITY=polygon,finnhub,twelvedata,alphavantage
POLYGON_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=

# Dashboard defaults (comma-separated symbols; use exchange format your provider expects, e.g. RELIANCE.NS)
ANALYTICS_INDEX_SYMBOLS=SPY,QQQ,DIA
ANALYTICS_DEFAULT_WATCHLIST=AAPL,MSFT,GOOGL
ANALYTICS_SECTOR_ETFS=XLK,XLF,XLE,XLV,XLY,XLP,XLI,XLB,XLRE,XLU

# Premium cookie: set `vv_premium_access` from your billing/auth service:
# payload = { tier: "navigator", exp: unixSeconds }
# body = Buffer.from(JSON.stringify(payload)).toString("base64url")
# sig = createHmac("sha256", PREMIUM_ACCESS_SECRET).update(body).digest("base64url")
# cookie value = `${body}.${sig}` (URL-encoded)
